datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
  binaryTargets = ["native"]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String
  imageUrl        String // chosen or uploaded picture
  picturePassword String // Argon2 hash of the grid sequence
  sessions        Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
